{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://magifab.vercel.app",
          "http://localhost:5173",
          "http://localhost:3000"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["Range"]
      },
      "exposeHeaders": ["Accept-Ranges", "Content-Length", "Content-Range", "ETag"],
      "maxAgeSeconds": 86400
    }
  ]
}
