# Server-side provider credentials. Do not expose these values to the frontend.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional provider overrides.
OPENAI_MODEL=gpt-5.6
GEMINI_MODEL=gemini-2.5-flash

# Optional local development settings.
MAGIFAB_MOVIE_PIPELINE_DIR=cache/movie-pipeline
MAGIFAB_MOVIE_CHUNK_DURATION_SECONDS=90

# Bundled example books are auto-discovered from:
# - backend/assets/books/
# - backend/books/
